# ==============================================================================
# useAxiom Workspace Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' at the root of the project to set up local environment variables.
# Do not commit credentials/secret values to git repository history.

# ------------------------------------------------------------------------------
# Core Server Configuration
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
# Default credentials mapped from infra/docker/docker-compose.yml
DB_USER=axiom_user
DB_PASSWORD=axiom_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axiom_db

# Connection URL utilized by Prisma and ORM clients
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# ------------------------------------------------------------------------------
# Cache & Message Broker (Redis for BullMQ)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ------------------------------------------------------------------------------
# Authentication & Security
# ------------------------------------------------------------------------------
JWT_SECRET=super_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# AI Provider Abstractions (LLM API keys)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# WhatsApp Business API Credentials
# ------------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=your_meta_system_user_access_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_arbitrary_webhook_verification_token_here
WHATSAPP_API_VERSION=v20.0
